{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "io.han.c-block-algorithm-panel",
  "productName": "AlgoLatch",
  "asar": true,
  "directories": {
    "output": "release-beta"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json",
    "package-lock.json",
    "LICENSE",
    "NOTICE.md",
    "THIRD_PARTY_NOTICES.md",
    "PRIVACY.md",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "mac": {
    "category": "public.app-category.education",
    "icon": "build/icon.icns",
    "identity": null,
    "hardenedRuntime": false,
    "notarize": false,
    "target": [
      {
        "target": "dmg",
        "arch": ["universal"]
      }
    ],
    "artifactName": "AlgoLatch-${version}-unsigned-${arch}.${ext}"
  },
  "dmg": {
    "sign": false,
    "title": "AlgoLatch ${version}",
    "backgroundColor": "#ffffff",
    "contents": [
      {
        "x": 140,
        "y": 220
      },
      {
        "x": 400,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  }
}
